@import url("https://fonts.googleapis.com/css2?family=Geist:wght@400;600;700&family=JetBrains+Mono:wght@400;500;700&display=swap");
@import "tailwindcss";

@theme {
  --color-void: #050505;
  --color-surface: #131313;
  --color-surface-dim: #131313;
  --color-surface-bright: #3a3939;
  --color-surface-container-lowest: #0e0e0e;
  --color-surface-container-low: #1c1b1b;
  --color-surface-container: #201f1f;
  --color-surface-container-high: #2a2a2a;
  --color-surface-container-highest: #353534;
  --color-surface-charcoal: #111111;

  --color-on-surface: #e5e2e1;
  --color-on-surface-variant: #bdc9c5;
  --color-outline: #879390;
  --color-outline-variant: #3e4946;

  --color-primary: #7ad7c6;
  --color-primary-on: #003730;
  --color-primary-container: #0c7e70;
  --color-primary-on-container: #cefff4;

  --color-secondary: #e6feff;
  --color-secondary-on: #003739;
  --color-secondary-container: #00f4fe;

  --color-tertiary: #ffb59f;
  --color-tertiary-on: #581e0a;
  --color-tertiary-container: #a85b43;

  --color-error: #ffb4ab;
  --color-error-on: #690005;
  --color-error-container: #93000a;

  --color-matrix: #0c7e70;
  --color-cyan: #00f5ff;

  --font-sans: "Geist", system-ui, sans-serif;
  --font-mono: "JetBrains Mono", ui-monospace, monospace;

  --radius-sm: 0.125rem;
  --radius-md: 0.375rem;
  --radius-lg: 0.5rem;
  --radius-xl: 0.75rem;

  --animate-pulse-cyan: pulse-cyan 1.6s ease-in-out infinite;
  --animate-blink: blink 1s step-end infinite;
}

@keyframes pulse-cyan {

  0%,
  100% {
    opacity: 1;
  }

  50% {
    opacity: 0.4;
  }
}

@keyframes blink {

  0%,
  49% {
    opacity: 1;
  }

  50%,
  100% {
    opacity: 0;
  }
}

html,
body {
  background-color: #050505;
  color: #e5e2e1;
  font-family: "Geist", system-ui, sans-serif;
}

.glass-panel {
  background-color: rgba(255, 255, 255, 0.03);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 0.75rem;
}

.glass-panel-active {
  background-color: rgba(255, 255, 255, 0.03);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 0.75rem;
  box-shadow: 0 0 24px rgba(12, 126, 112, 0.15);
}

.terminal-input-line {
  border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  transition: border-color 0.2s ease, box-shadow 0.2s ease;
}

.terminal-input-line:focus-within {
  border-bottom-color: #00f5ff;
  box-shadow: 0 1px 0 0 #00f5ff, 0 0 16px rgba(0, 245, 255, 0.25);
}

.status-dot-active {
  background-color: #00f5ff;
}

.status-dot-stable {
  background-color: #0c7e70;
}

.status-dot-error {
  background-color: #ff4d4d;
}

::selection {
  background-color: rgba(122, 215, 198, 0.3);
}

::-webkit-scrollbar {
  width: 6px;
}

::-webkit-scrollbar-thumb {
  background-color: #3e4946;
  border-radius: 9999px;
}

::-webkit-scrollbar-track {
  background-color: transparent;
}